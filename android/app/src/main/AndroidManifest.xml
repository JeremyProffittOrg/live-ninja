<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <!-- Session FGS expands to microphone|mediaPlayback while a realtime call is live. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <!-- Wake the screen over the keyguard on wake-word detection (01-platform §B-ii). -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <!-- Session-scoped PARTIAL_WAKE_LOCK so Doze cannot stall a screen-off session. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Battery-optimization exemption prompt (onboarding + Settings health card). -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- Live-session floating bubble (TYPE_APPLICATION_OVERLAY). Optional —
         requested via Settings.ACTION_MANAGE_OVERLAY_PERMISSION in onboarding;
         LiveOverlayController no-ops without the user grant. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Package visibility (API 30+): AssistantRoleController resolve-checks the
         OEM assistant-settings deep-link candidates before launching them. -->
    <queries>
        <intent>
            <action android:name="android.settings.VOICE_INPUT_SETTINGS" />
        </intent>
        <intent>
            <action android:name="android.settings.MANAGE_DEFAULT_APPS_SETTINGS" />
        </intent>
        <intent>
            <action android:name="android.settings.SETTINGS" />
        </intent>
        <package android:name="com.android.settings" />
    </queries>

    <application
        android:name=".LiveNinjaApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.LiveNinja">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- LWA broker return: /auth/lwa/callback 302s the one-shot handoff
                 code here (ninja.jeremy.liveninja://lwa). LWA never sees this
                 scheme, so no assetlinks.json / portal redirect URI is needed. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="ninja.jeremy.liveninja"
                    android:host="lwa" />
            </intent-filter>
        </activity>

        <!-- Assistant role anchor (ROLE_ASSISTANT). Bound by the system while
             Live Ninja is the default digital assistant; metadata wires the
             session + recognition services (Android §2). -->
        <service
            android:name=".assistant.LiveNinjaVoiceInteractionService"
            android:exported="true"
            android:label="@string/assistant_service_label"
            android:permission="android.permission.BIND_VOICE_INTERACTION">
            <intent-filter>
                <action android:name="android.service.voice.VoiceInteractionService" />
            </intent-filter>
            <meta-data
                android:name="android.voice_interaction"
                android:resource="@xml/interaction_service" />
        </service>

        <!-- Creates LiveNinjaSession instances for assist gestures / keyguard
             voice assist; referenced from xml/interaction_service.xml. -->
        <service
            android:name=".assistant.LiveNinjaSessionService"
            android:exported="true"
            android:permission="android.permission.BIND_VOICE_INTERACTION" />

        <!-- Required companion of a voice-interaction service. Declines
             external recognition requests (realtime-session-only recognizer). -->
        <service
            android:name=".assistant.LiveNinjaRecognitionService"
            android:exported="true"
            android:label="@string/recognition_service_label">
            <intent-filter>
                <action android:name="android.speech.RecognitionService" />
            </intent-filter>
            <meta-data
                android:name="android.speech"
                android:resource="@xml/recognition_service" />
        </service>

        <!-- Always-listening wake-word FGS (plan.md M4, Android §3.2). -->
        <service
            android:name=".wake.WakeWordService"
            android:exported="false"
            android:foregroundServiceType="microphone|mediaPlayback" />

        <!-- Restart the wake service after reboot / app update when enabled. Only the system
             can send these protected broadcasts, so exported is safe and required for
             delivery on all OEMs. -->
        <receiver
            android:name=".wake.WakeBootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
